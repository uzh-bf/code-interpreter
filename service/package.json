{
  "name": "code-execution-lambda",
  "version": "1.0.2",
  "main": "index.js",
  "scripts": {
    "reinstall": "node ./config/update.js",
    "start:file-server": "ts-node src/file-server.ts",
    "start:tool-call-server": "bun run src/tool-call-server.ts",
    "start:minio": "ts-node src/files/server.ts",
    "debug:minio": "node --inspect=0.0.0.0:9230 -r ts-node/register/transpile-only src/file-server.ts",
    "start:service": "node .build-service/src/service-api.js",
    "start:debug": "node --inspect=0.0.0.0:9230 -r ts-node/register/transpile-only src/service-api.ts",
    "start:api": "node .build-service/src/api-server.js",
    "start:api:dev": "ts-node src/api-server.ts",
    "start:worker": "node .build-service/src/worker-server.js",
    "start:worker:dev": "ts-node src/worker-server.ts",
    "start:egress-gateway": "bun run src/egress-gateway.ts",
    "build": "rollup -c",
    "deploy": "serverless deploy",
    "test": "bun test ./src/*.test.ts ./src/*.spec.ts ./src/**/*.test.ts ./src/**/*.spec.ts",
    "test:ptc": "bun run scripts/test-ptc-sentinel.ts && bun run scripts/test-replay-state.ts",
    "test:ptc:smoke": "bun run scripts/test-ptc-sentinel.ts && bun run scripts/test-replay-state.ts && bun run scripts/test-ptc-replay-smoke.ts && bun run scripts/test-ptc-replay-bash-smoke.ts"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "description": "",
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/core": "2.7.1",
    "@opentelemetry/exporter-trace-otlp-proto": "0.218.0",
    "@opentelemetry/resources": "2.7.1",
    "@opentelemetry/sdk-trace-base": "2.7.1",
    "axios": "^1.8.4",
    "bullmq": "^5.13.1",
    "busboy": "^1.6.0",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.1",
    "ioredis": "^5.4.1",
    "minio": "^8.0.5",
    "nanoid": "^3.3.7",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.2.0",
    "winston": "^3.14.2"
  },
  "imports": {
    "@/*": "./src/*",
    "~/*": "./*"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^5.1.1",
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-typescript": "^12.1.1",
    "@types/bun": "^1.3.14",
    "@types/busboy": "^1.5.4",
    "@types/express": "^4.17.21",
    "@types/ioredis-mock": "^8.2.7",
    "@types/nanoid": "^3.0.0",
    "@types/node": "^22.5.5",
    "@typescript-eslint/eslint-plugin": "^8.0.1",
    "@typescript-eslint/parser": "^8.0.1",
    "eslint": "^8.57.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import": "^2.29.1",
    "ioredis-mock": "^8.13.1",
    "rollup": "^2.79.2",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-sourcemaps": "^0.6.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
